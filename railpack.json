{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "20.20.2"
  },
  "aptPackages": ["python3", "make", "g++", "build-essential", "libsqlite3-dev"],
  "install": {
    "cmds": ["npm install --legacy-peer-deps"]
  },
  "start": {
    "cmd": "node init-credentials.js || true && node index"
  }
}
